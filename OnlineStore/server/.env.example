# ===========================================
# Mini 在线商城 - 环境变量模板
# 复制此文件为 .env 并填写实际值
# ===========================================

NODE_ENV=development
PORT=3000

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=online_store
DB_CONNECTION_LIMIT=10

# CORS
CORS_ORIGIN=http://localhost:5173

# 分页默认值
PAGE_SIZE_DEFAULT=20
PAGE_SIZE_MAX=100

# 业务配置
STOCK_ALERT_THRESHOLD=10
